generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 4 ADD
model Task {
  id          Int       @id @default(autoincrement())
  text        String
  completed   Boolean   @default(false)
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}