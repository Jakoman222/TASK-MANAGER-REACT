```env
# ==========================================
# BACKEND
# ==========================================

# Puerto interno donde escucha Express
PORT=3000

# Cadena de conexión PostgreSQL de Neon
# Reemplaza usuario, contraseña, host y base de datos.
DATABASE_URL=postgresql://usuario:contraseña@host-neon/neondb?sslmode=require

# Clave utilizada para firmar y verificar tokens JWT
# Usa un valor largo y aleatorio en el archivo .env real.
SECRET_KEY=replace_with_a_secure_random_secret
```
